# --- CareerOS frontend config ---

# Route or absolute URL used by every "Start with your resume" CTA.
# The cinematic landing leads into the full Command Center (/app),
# which wires all 15 backend modules into the same UI.
NEXT_PUBLIC_GET_STARTED_URL=/app

# Base URL of the CareerOS FastAPI backend.
# Local dev (backend on :8000):
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Prod example: https://api.careeros.app

# --- Clerk authentication ---
# Get keys from https://dashboard.clerk.com -> API Keys.
# When these are set, /app is protected and sign-in/up pages activate.
# When absent, the app runs keyless (auth disabled) for local dev.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Where Clerk sends users for auth + after auth:
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app
