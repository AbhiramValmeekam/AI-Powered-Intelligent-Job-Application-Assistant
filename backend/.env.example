# --- CareerOS backend config (copy to .env) ---

# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=careeros

# Gemini (LLM for intelligence modules)
GEMINI_API_KEY=

# Job Discovery — free APIs
# Adzuna: free key at https://developer.adzuna.com  (leave blank to skip)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# jobdataapi: free tier at https://jobdataapi.com  (needs key + explicit enable)
JOBDATAAPI_KEY=
JOBDATAAPI_ENABLED=false

# Scheduler
ALERT_INTERVAL_MIN=15

# CORS (comma-separated origins allowed to call the API)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Scam Shield model path (override in prod e.g. a Render Mount)
# JOBSHIELD_MODEL_DIR=/path/to/saved_models
