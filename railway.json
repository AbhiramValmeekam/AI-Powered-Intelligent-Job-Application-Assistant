{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "rootDirectory": "frontend",
    "buildCommand": "npm install && npm run build"
  },
  "deploy": {
    "rootDirectory": "frontend",
    "startCommand": "npm run start",
    "healthcheckPath": "/",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3
  }
}
